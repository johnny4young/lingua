exports[`email templates render against fixture vars > trial.html 1`] = `
"<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Your Lingua Pro trial is ready</title>
    <style></style>
  </head>
  <body>
    <div class="container">
      <div class="brand">Lingua</div>
      <div class="card">
        <h1>Your Pro trial is ready</h1>
        <p>Hi student@stanford.edu,</p>
        <p>Your free 14-day Lingua Pro trial is active. Paste the token below into Settings → License inside the app, or click the button if you opened this email on the same machine where Lingua is installed.</p>
        <p><a class="button" href="lingua://license?token=eyJsaWNlbnNlSWQiOiJsaWNfMSJ9.AAAAAAAAAAAAAAAAAAAAAA">Activate Pro</a></p>
        <p>Or paste this token manually:</p>
        <div class="token-box">eyJsaWNlbnNlSWQiOiJsaWNfMSJ9.AAAAAAAAAAAAAAAAAAAAAA</div>
        <p>Your trial expires on <strong>May 13, 2026</strong>. After that you can buy a Pro license at <a href="https://linguacode.dev">linguacode.dev</a> or apply for the free Education plan if you are a student.</p>
        <p class="muted">You are receiving this email because you started a free trial on Lingua. If this was not you, it is safe to ignore — the trial is locked to a single device and email.</p>
      </div>
    </div>
  </body>
</html>
"
`;
