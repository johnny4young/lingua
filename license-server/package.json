{
  "name": "lingua-license-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "migrations:apply:local": "wrangler d1 migrations apply lingua-licenses --local",
    "migrations:apply:remote": "wrangler d1 migrations apply lingua-licenses --remote"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250410.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.14.0"
  }
}
