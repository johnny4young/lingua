# Dependencies
node_modules/
# This repo is pnpm-only; ignore accidental lockfiles from other JS package managers.
package-lock.json
npm-shrinkwrap.json
yarn.lock
# Exception: website/ is a standalone npm package (see website/package.json);
# its lockfile MUST be committed so `npm ci` is reproducible in the deploy CI.
!website/package-lock.json

# Build output
out/
out-builder/
dist/
.vite/
.playwright-cli/
.playwright-mcp/
test-results/
Library/

# Website (Astro) generated artifacts. website/ ships its own .gitignore for
# these, but branches predating the website migration (and stray worktree
# state after a branch switch) have no website/.gitignore — this repo-root rule
# stops the Astro cache and the generated press-kit zip from being staged
# there. node_modules/ and dist/ above already cover website/node_modules and
# website/dist; the press-kit is produced by website/scripts/build-press-kit-zip.mjs.
website/.astro/
website/.cache/
website/public/press/lingua-press-kit.zip

# Local artifacts
output/
.audit/
tmp/
/PLAN.md
/TEST_PLAN.md
dev-license.json
assets/icon.iconset/

# Logs
*.log
npm-debug.log*

# Runtime data
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
*.lcov

# TypeScript cache
*.tsbuildinfo

# OS files
.DS_Store
Thumbs.db

# Environment
.env
.env.local
.env.*.local

# Secret material — belt-and-suspenders so a new worker/package dir without
# its own .gitignore cannot slip a credentials file into a now-public repo.
*.dev.vars
.dev.vars
*.p12
*.pfx

# Editor
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo

# Optional caches
.npm
.eslintcache
.cache

# Agent per-developer state, including local command skills such as:
# .claude/skills/lingua-review/
# .claude/skills/lingua-ship/
# .agents/skills/lingua-review/
# .agents/skills/lingua-ship/
.mcp.json
.claude/
.agents/skills/lingua-review/
.agents/skills/lingua-ship/
prod-keypair.json
default.profraw

# Internal planning/strategy + agent workflow — local, never committed (public repo)
.agents/
/docs/ROADMAP.md
/docs/PLAN.md
/docs/BACKLOG.md
/docs/SPRINT-PLAN.md
/docs/ARCHIVED.md
/docs/ANTI_FEATURES.md
