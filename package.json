{
  "name": "lingua",
  "productName": "Lingua",
  "version": "0.5.0",
  "description": "Desktop application for running code in multiple languages with WebAssembly support",
  "packageManager": "pnpm@11.3.0",
  "main": ".vite/build/main.js",
  "bin": {
    "lingua": "./dist/cli/lingua.cjs"
  },
  "private": true,
  "scripts": {
    "dev:web": "vite --config vite.web.config.mts --port 5174",
    "dev:web:pro": "node ./scripts/dev-web-pro.mjs",
    "dev:desktop": "node ./scripts/run-electron-desktop.mjs",
    "dev:desktop:sync": "node ./scripts/run-electron-desktop.mjs --sync-main",
    "dev:desktop:pro": "node ./scripts/dev-desktop-pro.mjs",
    "dev:desktop:prod": "node ./scripts/dev-desktop-prod.mjs",
    "dev:desktop:forge": "electron-forge start",
    "build:web": "vite build --config vite.web.config.mts",
    "build:cli": "node ./scripts/build-cli.mjs",
    "preview:web": "vite preview --config vite.web.config.mts",
    "smoke:desktop": "node ./scripts/run-desktop-smoke.mjs",
    "smoke:desktop:stagewright": "node ./scripts/run-electron-stagewright-smoke.mjs",
    "smoke:desktop:offline": "node ./scripts/run-desktop-smoke.mjs --offline",
    "smoke:desktop:packaged": "node ./scripts/run-desktop-smoke.mjs --offline --against-packaged out/make",
    "build:runtime-assets": "node --experimental-strip-types ./scripts/build-runtime-asset-manifest.mjs --write",
    "check:runtime-assets": "node --experimental-strip-types ./scripts/build-runtime-asset-manifest.mjs",
    "sbom:release": "node ./scripts/write-release-compliance-artifacts.mjs",
    "check:licenses": "node ./scripts/check-third-party-licenses.mjs --check",
    "license:report": "node ./scripts/check-third-party-licenses.mjs --format markdown --write docs/THIRD_PARTY_LICENSE_REPORT.md",
    "compliance:release": "node ./scripts/write-release-compliance-artifacts.mjs",
    "check:update-feed": "node ./scripts/validate-update-feed.mjs",
    "check:r2-mirror": "node ./scripts/check-r2-mirror.mjs",
    "performance:report": "node ./scripts/performance-report.mjs",
    "performance:baseline": "node ./scripts/performance-report.mjs --write-baseline --require-all-targets",
    "check:performance": "node ./scripts/performance-report.mjs --check",
    "changelog:draft": "node ./scripts/changelog-draft.mjs",
    "changelog:check": "node ./scripts/changelog-check.mjs",
    "test": "vitest run",
    "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
    "test:e2e:web": "PLAYWRIGHT_BROWSERS_PATH=0 node ./scripts/run-playwright-web-validation.mjs",
    "test:smoke:web:license": "vitest run tests/smoke/licenseWebSmoke.test.tsx",
    "test:watch": "vitest",
    "lint": "eslint .",
    "check:i18n": "node ./scripts/check-i18n.mjs",
    "check:i18n:copy": "node ./scripts/check-renderer-copy.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "package:desktop": "electron-forge package",
    "make:desktop": "electron-forge make",
    "make:desktop:mac": "electron-forge make --platform darwin",
    "make:desktop:linux": "electron-forge make --platform linux",
    "make:desktop:win": "electron-forge make --platform win32",
    "publish:desktop": "electron-forge publish",
    "prepare": "node ./scripts/build-cli.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/johnny4young/lingua"
  },
  "keywords": [
    "code-runner",
    "electron",
    "monaco-editor",
    "wasm",
    "multi-language"
  ],
  "author": {
    "name": "johnny4young",
    "email": "asesordeprogramacion@gmail.com"
  },
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/spark-md5": "^3.0.5",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "electron": "^42.1.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.13",
    "vitest": "^4.1.6",
    "wrangler": "^4.14.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@duckdb/duckdb-wasm": "^1.29.0",
    "@jridgewell/trace-mapping": "^0.3.31",
    "@monaco-editor/react": "^4.7.0",
    "@prettier/plugin-xml": "^3.4.2",
    "@ruby/3.4-wasm-wasi": "2.9.3-2.9.4",
    "@ruby/wasm-wasi": "2.9.3-2.9.4",
    "acorn": "^8.16.0",
    "cron-parser": "^5.5.0",
    "cronstrue": "^3.14.0",
    "dompurify": "^3.4.1",
    "electron-squirrel-startup": "^1.0.1",
    "esbuild-wasm": "^0.28.0",
    "fengari": "^0.1.5",
    "fflate": "^0.8.3",
    "i18next": "^26.0.8",
    "js-yaml": "^4.1.1",
    "jsqr": "^1.4.0",
    "lucide-react": "^1.11.0",
    "magic-string": "^0.30.21",
    "marked": "^18.0.2",
    "monaco-editor": "^0.55.1",
    "monaco-vim": "^0.4.4",
    "pyodide": "^0.29.4",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "react-resizable-panels": "^4.10.0",
    "spark-md5": "^3.0.2",
    "sql-formatter": "^15.7.3",
    "terser": "^5.46.2",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.3",
    "zustand": "^5.0.12"
  },
  "engines": {
    "node": "24.x"
  },
  "overrides": {
    "dompurify": "$dompurify"
  }
}
