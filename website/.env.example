# Optional: set LINGUA_SOURCE=local to skip the GitHub Releases API during
# `npm run dev` / `npm run build`. The build synthesizes a placeholder
# multi-platform release from changelog.json so the page renders offline.
LINGUA_SOURCE=

# Polar.sh checkout URLs (build-time)
# Prefixed with PUBLIC_ so Astro/Vite exposes them on import.meta.env without
# extra config. When unset, the corresponding Buy button renders disabled with
# a "Checkout coming soon" tooltip.
PUBLIC_POLAR_CHECKOUT_PRO=
PUBLIC_POLAR_CHECKOUT_PRO_LIFETIME=
PUBLIC_POLAR_CHECKOUT_TEAM=

# Optional: Cloudflare Web Analytics token (no other analytics ever)
PUBLIC_CF_ANALYTICS_TOKEN=
