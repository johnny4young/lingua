---
import Base from './Base.astro';
import type { CollectionEntry } from 'astro:content';
import { type Locale, localizePath, t } from '~/lib/i18n';

interface Props {
  entry: CollectionEntry<'docs'>;
  allDocs: CollectionEntry<'docs'>[];
  locale: Locale;
}

const { entry, allDocs, locale } = Astro.props;
const { title, description } = entry.data;
const copy = t(locale);

const COMING_SOON = copy.docs.comingSoon.filter((item) => !allDocs.some((doc) => doc.id.endsWith(`/${item.id}`)));

const sortedDocs = [...allDocs].sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const slugFor = (id: string) => id.replace(/^(en|es)\//, '');
const activeSlug = slugFor(entry.id);
---

<Base title={`${title} — ${copy.docs.titleSuffix}`} description={description} locale={locale}>
  <div class="container doc-shell">
    <aside class="doc-nav" aria-label={copy.docs.navLabel}>
      <p class="eyebrow">{copy.docs.label}</p>
      <nav>
        <ul>
          {
            sortedDocs.map((d) => (
              <li>
                <a
                  href={localizePath(locale, `/docs/${slugFor(d.id)}`)}
                  class:list={['doc-link', slugFor(d.id) === activeSlug && 'is-active']}
                >
                  {d.data.title}
                </a>
              </li>
            ))
          }
          {
            COMING_SOON.map((cs) => (
              <li>
                <span class="doc-link is-pending">
                  {cs.title}
                  <span class="tag">{copy.common.comingSoon}</span>
                </span>
              </li>
            ))
          }
        </ul>
      </nav>
    </aside>

    <article class="doc-body">
      <header>
        <h1>{title}</h1>
        <p class="doc-lede">{description}</p>
      </header>
      <div class="prose">
        <slot />
      </div>
    </article>
  </div>
</Base>

<style>
  .doc-shell {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    padding-block: var(--space-section);
    min-width: 0;
  }
  .doc-nav {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1.5rem;
    min-width: 0;
  }
  .doc-body {
    min-width: 0;
  }
  .doc-nav nav ul {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .doc-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0.75rem;
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    font-size: var(--text-small);
    border-left: 2px solid transparent;
    transition: color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }
  .doc-link:hover {
    color: var(--color-text);
    background: var(--color-bg-elevated);
  }
  .doc-link.is-active {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent-muted) 30%, transparent);
  }
  .doc-link.is-pending {
    color: var(--color-text-subtle);
    cursor: default;
  }
  .doc-link.is-pending:hover {
    background: transparent;
    color: var(--color-text-subtle);
  }
  .doc-body header {
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }
  .doc-body h1 {
    font-size: var(--text-h1);
    letter-spacing: var(--tracking-tight);
    font-weight: 800;
    margin: 0 0 1rem;
  }
  .doc-lede {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    margin: 0;
  }
  @media (min-width: 1024px) {
    .doc-shell {
      grid-template-columns: 240px 1fr;
      gap: 4rem;
    }
    .doc-nav {
      border-bottom: 0;
      border-right: 1px solid var(--color-border);
      padding-right: 1.5rem;
      padding-bottom: 0;
      position: sticky;
      top: 80px;
      align-self: start;
    }
  }
</style>
