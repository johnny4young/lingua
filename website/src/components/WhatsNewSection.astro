---
import { loadChangelog } from '~/lib/changelog';
import { type Locale, localizePath, t } from '~/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = t(locale);
const block = copy.home.whatsNew;

// The current release stays fully visible; everything older collapses
// into the history timeline below. Data comes from the preprocessed
// changelog.json (synced at build time — zero network dependency).
const entries = await loadChangelog();
const current = entries[0];
const previous = entries.slice(1);

const LEAD_RE = /<strong>(.+?)<\/strong>\s*[:—-]?\s*([\s\S]*)/;

function stripTags(html: string): string {
  return html.replace(/<[^>]+>/g, '');
}

// Chip labels and tooltips come from changelog HTML, so nested tags
// (<code>…</code>) must go and entities (&amp;) must decode exactly
// once — Astro re-escapes on render.
function decodeEntities(text: string): string {
  return text
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'")
    .replace(/&amp;/g, '&');
}

function toPlainText(html: string): string {
  return decodeEntities(stripTags(html)).replace(/\s+/g, ' ').trim();
}

interface FeatureLead {
  lead: string;
  tip: string;
}

function leadsFor(entry: (typeof entries)[number]): FeatureLead[] {
  const leads: FeatureLead[] = [];
  for (const section of entry.sections) {
    for (const item of section.items) {
      const match = item.match(LEAD_RE);
      if (!match?.[1]) continue;
      leads.push({
        lead: toPlainText(match[1]),
        tip: toPlainText(match[2] ?? ''),
      });
    }
  }
  return leads;
}

function formatDate(iso: string): string {
  try {
    return new Intl.DateTimeFormat(locale === 'es' ? 'es' : 'en', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    }).format(new Date(`${iso}T12:00:00Z`));
  } catch {
    return iso;
  }
}

const history = previous.map((entry) => ({
  version: entry.version,
  date: formatDate(entry.date),
  leads: leadsFor(entry),
}));
---

<section class="whats-new">
  <header class="whats-new-head">
    <p class="eyebrow">{block.eyebrow}</p>
    <h2>{block.title}</h2>
    <p class="lede">{block.lede}</p>
  </header>

  <div class="whats-new-grid">
    {
      block.items.map((item, index) => (
        <article class:list={['card', 'whats-new-card', { featured: index === 0 }]}>
          <div class="shot-frame">
            <img src={item.image} alt={item.alt} loading="lazy" decoding="async" />
          </div>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))
    }
  </div>

  <p class="whats-new-cta">
    <a href={localizePath(locale, '/changelog')}>{block.cta} →</a>
  </p>

  {
    history.length > 0 && (
      <div class="history">
        <h3 class="history-title">{block.history.title}</h3>
        <p class="history-lede">{block.history.lede}</p>
        <ol class="history-list" reversed>
          {history.map((release) => (
            <li class="history-item">
              <details>
                <summary>
                  <span class="history-version">v{release.version}</span>
                  <span class="history-date">{release.date}</span>
                  <span class="history-count">
                    {release.leads.length}{' '}
                    {release.leads.length === 1
                      ? block.history.featureLabel
                      : block.history.featuresLabel}
                  </span>
                  <span class="history-chevron" aria-hidden="true">
                    +
                  </span>
                </summary>
                <ul class="history-leads">
                  {release.leads.map((feature, featureIndex) => {
                    const tipId = feature.tip
                      ? `lead-tip-${release.version.replace(/\./g, '-')}-${featureIndex}`
                      : undefined;
                    return (
                      <li tabindex={feature.tip ? 0 : undefined} aria-describedby={tipId}>
                        {feature.lead}
                        {feature.tip && (
                          <span class="lead-tip" role="tooltip" id={tipId}>
                            {feature.tip}
                          </span>
                        )}
                      </li>
                    );
                  })}
                </ul>
              </details>
            </li>
          ))}
        </ol>
      </div>
    )
  }
</section>

<style>
  .whats-new {
    padding-block: var(--space-section);
  }
  .whats-new-head {
    max-width: 760px;
    margin-bottom: 2.5rem;
  }
  .whats-new-head h2 {
    font-size: var(--text-h2);
    letter-spacing: var(--tracking-tight);
    font-weight: 700;
    margin: 0.75rem 0 0;
    line-height: 1.2;
  }
  .whats-new-head .lede {
    color: var(--color-text-muted);
    margin: 0.75rem 0 0;
    line-height: 1.6;
  }
  .whats-new-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  .whats-new-card h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 1rem 0 0.5rem;
  }
  .whats-new-card p {
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
  }
  .shot-frame {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: #0b0f15;
  }
  .shot-frame img {
    display: block;
    width: 100%;
    height: 180px;
    object-fit: contain;
    padding: 10px;
    box-sizing: border-box;
  }
  .whats-new-cta {
    margin-top: 2rem;
  }
  .whats-new-cta a {
    color: var(--color-accent);
    font-weight: 600;
    text-decoration: none;
  }
  .whats-new-cta a:hover {
    text-decoration: underline;
  }

  /* ── Release history — collapsed timeline of everything older ── */
  .history {
    margin-top: clamp(2.5rem, 6vw, 4rem);
    border-top: 1px solid var(--color-border);
    padding-top: clamp(2rem, 5vw, 3rem);
  }
  .history-title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    margin: 0 0 0.5rem;
  }
  .history-lede {
    color: var(--color-text-muted);
    margin: 0 0 1.75rem;
    max-width: 62ch;
  }
  .history-list {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
  }
  /* timeline spine */
  .history-list::before {
    content: "";
    position: absolute;
    left: 5px;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: var(--color-border);
  }
  .history-item {
    position: relative;
    padding-left: 2rem;
  }
  .history-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 1.05rem;
    width: 11px;
    height: 11px;
    border-radius: 3px;
    background: var(--color-bg);
    border: 1.5px solid var(--color-border-strong);
    transition: border-color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out);
  }
  .history-item:has(details[open])::before {
    border-color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 24%, var(--color-bg));
  }
  .history-item + .history-item {
    margin-top: 0.25rem;
  }
  .history-item summary {
    display: flex;
    align-items: baseline;
    gap: 0.875rem;
    padding: 0.7rem 0.75rem;
    border-radius: var(--radius);
    cursor: pointer;
    list-style: none;
    transition: background var(--duration-fast) var(--ease-out);
  }
  .history-item summary::-webkit-details-marker {
    display: none;
  }
  .history-item summary:hover {
    background: color-mix(in srgb, var(--color-bg-elevated) 70%, transparent);
  }
  .history-version {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: var(--text-small);
    color: var(--color-text);
    min-width: 4.5rem;
  }
  .history-date {
    color: var(--color-text-subtle);
    font-size: var(--text-small);
  }
  .history-count {
    color: var(--color-text-subtle);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    margin-left: auto;
  }
  .history-chevron {
    color: var(--color-text-subtle);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    width: 1rem;
    text-align: center;
    transition: transform var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }
  details[open] .history-chevron {
    transform: rotate(45deg);
    color: var(--color-accent);
  }
  .history-leads {
    list-style: none;
    margin: 0.25rem 0 1rem;
    padding: 0 0.75rem 0 5.6rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .history-leads li {
    position: relative;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg-elevated) 80%, transparent);
    border-radius: var(--radius-sm);
    padding: 0.3rem 0.6rem;
    line-height: 1.45;
    cursor: default;
    transition: border-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }
  .history-leads li:hover,
  .history-leads li:focus-visible {
    border-color: var(--color-accent-muted);
    color: var(--color-text);
  }

  /* Hover / focus tooltip — the changelog entry's own description. */
  .lead-tip {
    position: absolute;
    left: 0;
    bottom: calc(100% + 8px);
    z-index: 20;
    width: max-content;
    max-width: min(52ch, calc(100vw - 3rem));
    padding: 0.6rem 0.8rem;
    font-size: var(--text-xs);
    line-height: 1.55;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius);
    box-shadow: var(--shadow-lift);
    opacity: 0;
    visibility: hidden;
    transform: translateY(4px);
    pointer-events: none;
    transition: opacity var(--duration-fast) var(--ease-out),
      transform var(--duration-fast) var(--ease-out),
      visibility 0s linear var(--duration-fast);
  }
  .history-leads li:hover .lead-tip,
  .history-leads li:focus-visible .lead-tip {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition-delay: 150ms, 150ms, 150ms;
  }
  /* Chips on the right half anchor their tooltip to the right edge so
     long descriptions never overflow the viewport. Placed by script. */
  .history-leads li.tip-right .lead-tip {
    left: auto;
    right: 0;
  }

  @media (min-width: 768px) {
    .whats-new-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
    /* The headline feature of the release gets the wide slot. */
    .whats-new-card.featured {
      grid-column: span 3;
      display: grid;
      grid-template-columns: 1.4fr 1fr;
      gap: 1.5rem;
      align-items: center;
      background:
        radial-gradient(30rem 16rem at 8% 0%, color-mix(in srgb, var(--color-accent) 7%, transparent), transparent 70%),
        var(--color-bg-elevated);
    }
    .whats-new-card.featured .shot-frame {
      grid-row: span 2;
      align-self: stretch;
      display: grid;
    }
    .whats-new-card.featured .shot-frame img {
      height: 100%;
      min-height: 230px;
    }
    .whats-new-card.featured h3 {
      font-size: 1.4rem;
      margin-top: 0;
      align-self: end;
    }
    .whats-new-card.featured p {
      align-self: start;
    }
  }
  @media (min-width: 768px) and (max-width: 1099px) {
    .whats-new-card:not(.featured) {
      grid-column: span 1;
    }
  }
  @media (max-width: 767px) {
    .history-leads {
      padding-left: 0.75rem;
    }
  }
</style>
