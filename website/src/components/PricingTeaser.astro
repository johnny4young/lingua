---
import { type Locale, localizePath, t } from '~/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = t(locale);
const TIERS = copy.home.pricingTeaser.tiers;
---

<section class="pricing-teaser">
  <header class="teaser-head">
    <p class="eyebrow">{copy.home.pricingTeaser.eyebrow}</p>
    <h2>{copy.home.pricingTeaser.title}</h2>
    <p class="teaser-lede">{copy.home.pricingTeaser.lede}</p>
  </header>

  <div class="tier-grid">
    {
      TIERS.map((t, index) => (
        <article class="card tier-card">
          <span class="tier-index">{index + 1}</span>
          {t.tag && <span class="tier-tag">{t.tag}</span>}
          <h3>{t.name}</h3>
          <p class="tier-price">{t.price}</p>
          <p class="tier-desc">{t.desc}</p>
        </article>
      ))
    }
  </div>

  <div class="teaser-cta">
    <a href={localizePath(locale, '/pricing')} class="btn btn-secondary">{copy.common.seeFullComparison}</a>
  </div>
</section>

<style>
  .pricing-teaser {
    padding-block: var(--space-section);
  }
  .teaser-head {
    max-width: 760px;
    margin-bottom: 2.5rem;
  }
  .teaser-head h2 {
    font-size: var(--text-h2);
    letter-spacing: var(--tracking-tight);
    font-weight: 700;
    margin: 0.75rem 0 1rem;
  }
  .teaser-lede {
    color: var(--color-text-muted);
    margin: 0;
  }
  .tier-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .tier-card {
    position: relative;
    min-height: 190px;
    padding-top: 2rem;
  }
  .tier-index {
    position: absolute;
    top: 1rem;
    left: 1rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
  }
  .tier-tag {
    position: absolute;
    top: 1rem;
    right: 1rem;
    padding: 0.125rem 0.625rem;
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    background: color-mix(in srgb, var(--color-accent-muted) 30%, transparent);
    color: var(--color-accent);
    border: 1px solid var(--color-accent-muted);
    border-radius: var(--radius-sm);
    letter-spacing: 0;
  }
  .tier-card h3 {
    font-size: 1.125rem;
    font-weight: 700;
    margin: 1.5rem 0 0.5rem;
  }
  .tier-price {
    font-family: var(--font-mono);
    color: var(--color-accent);
    margin: 0 0 0.75rem;
    font-size: 1rem;
  }
  .tier-desc {
    color: var(--color-text-muted);
    margin: 0;
    font-size: var(--text-small);
    line-height: 1.5;
  }
  .teaser-cta {
    display: flex;
    justify-content: flex-start;
  }
  @media (min-width: 768px) {
    .tier-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
</style>
