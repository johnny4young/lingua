---
import { type Locale, t } from '~/lib/i18n';

interface Props {
  locale: Locale;
}

interface LangRow {
  name: string;
  state: 'runnable' | 'view-only';
  runtimeKey: 'js' | 'ts' | 'py' | 'go' | 'rust' | 'monaco';
  accessKey: 'free' | 'pro' | 'allTiers';
}

const { locale } = Astro.props;
const copy = t(locale).home.languageMatrix;

const LANGS: LangRow[] = [
  { name: 'JavaScript', state: 'runnable', runtimeKey: 'js', accessKey: 'free' },
  { name: 'TypeScript', state: 'runnable', runtimeKey: 'ts', accessKey: 'free' },
  { name: 'Python', state: 'runnable', runtimeKey: 'py', accessKey: 'free' },
  { name: 'Go', state: 'runnable', runtimeKey: 'go', accessKey: 'pro' },
  { name: 'Rust', state: 'runnable', runtimeKey: 'rust', accessKey: 'pro' },
  { name: 'Ruby', state: 'view-only', runtimeKey: 'monaco', accessKey: 'allTiers' },
  { name: 'Java', state: 'view-only', runtimeKey: 'monaco', accessKey: 'allTiers' },
  { name: 'Kotlin', state: 'view-only', runtimeKey: 'monaco', accessKey: 'allTiers' },
  { name: 'Scala', state: 'view-only', runtimeKey: 'monaco', accessKey: 'allTiers' },
  { name: 'Swift', state: 'view-only', runtimeKey: 'monaco', accessKey: 'allTiers' },
  { name: 'C', state: 'view-only', runtimeKey: 'monaco', accessKey: 'allTiers' },
  { name: 'C++', state: 'view-only', runtimeKey: 'monaco', accessKey: 'allTiers' },
];
---

<section class="lang-matrix">
  <header class="matrix-head">
    <p class="eyebrow">{copy.eyebrow}</p>
    <h2>{copy.title}</h2>
    <p>{copy.lede}</p>
  </header>

  <div class="matrix-card" role="table" aria-label={copy.aria}>
    <div class="matrix-row matrix-row-head" role="row">
      <span role="columnheader">{copy.columns.language}</span>
      <span role="columnheader">{copy.columns.status}</span>
      <span role="columnheader">{copy.columns.runtime}</span>
      <span role="columnheader">{copy.columns.tier}</span>
    </div>
    {
      LANGS.map((row) => (
        <div class="matrix-row" role="row">
          <span class="lang-name" role="cell">{row.name}</span>
          <span role="cell">
            <span class:list={['state-chip', row.state === 'runnable' ? 'is-runnable' : 'is-view']}>
              {row.state === 'runnable' ? copy.runnable : copy.viewOnly}
            </span>
          </span>
          <span class="lang-runtime" role="cell">{copy.notes[row.runtimeKey]}</span>
          <span class="lang-access" role="cell">{copy.access[row.accessKey]}</span>
        </div>
      ))
    }
  </div>
</section>

<style>
  .lang-matrix {
    padding-block: var(--space-section);
  }
  .matrix-head {
    margin-bottom: 2.5rem;
    max-width: 760px;
  }
  .matrix-head h2 {
    font-size: var(--text-h2);
    letter-spacing: var(--tracking-tight);
    font-weight: 700;
    margin: 0.75rem 0 0.75rem;
    line-height: 1.2;
  }
  .matrix-head p:not(.eyebrow) {
    color: var(--color-text-muted);
    margin: 0;
    max-width: 650px;
  }
  .matrix-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--color-bg-elevated) 90%, var(--color-bg-sunken));
    overflow: hidden;
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--color-text) 5%, transparent);
  }
  .matrix-row {
    display: grid;
    grid-template-columns: minmax(120px, 0.8fr) minmax(100px, 0.55fr) minmax(220px, 1.4fr) minmax(88px, 0.45fr);
    gap: 1rem;
    align-items: center;
    padding: 0.9rem 1rem;
    border-top: 1px solid var(--color-border);
  }
  .matrix-row:first-child {
    border-top: 0;
  }
  .matrix-row-head {
    background: var(--color-bg-sunken);
    color: var(--color-text-subtle);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0;
  }
  .lang-name {
    font-weight: 650;
    font-family: var(--font-mono);
    color: var(--color-text);
  }
  .lang-runtime,
  .lang-access {
    color: var(--color-text-muted);
    font-size: var(--text-small);
  }
  .state-chip {
    display: inline-flex;
    align-items: center;
    width: max-content;
    padding: 0.18rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    line-height: 1.2;
  }
  .state-chip.is-runnable {
    color: var(--color-accent);
    border-color: var(--color-accent-muted);
    background: color-mix(in srgb, var(--color-accent-muted) 22%, transparent);
  }
  .state-chip.is-view {
    color: var(--color-text-muted);
    background: color-mix(in srgb, var(--color-bg-sunken) 72%, transparent);
  }
  @media (max-width: 760px) {
    .matrix-card {
      display: grid;
      gap: 1px;
      background: var(--color-border);
      border: 0;
    }
    .matrix-row,
    .matrix-row:first-child {
      grid-template-columns: 1fr;
      gap: 0.45rem;
      padding: 1rem;
      border: 0;
      background: var(--color-bg-elevated);
    }
    .matrix-row-head {
      display: none;
    }
    .lang-runtime::before,
    .lang-access::before {
      display: inline;
      color: var(--color-text-subtle);
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      text-transform: uppercase;
      letter-spacing: 0;
    }
    .lang-runtime::before {
      content: "Runtime: ";
    }
    .lang-access::before {
      content: "Access: ";
    }
  }
</style>
