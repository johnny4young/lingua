---
import { Icon } from 'astro-icon/components';
import { loadChangelog } from '~/lib/changelog';
import { type Locale, t } from '~/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = t(locale).home.trust;

// internal — social proof that is verifiable, not testimonial theatre. The
// release count + first-release month come from the synced changelog.json
// at build time so the velocity claim can never drift out of date.
const entries = await loadChangelog();
const releaseCount = entries.length;
const firstDate = entries.at(-1)?.date;
const firstMonth = firstDate
  ? new Intl.DateTimeFormat(locale === 'es' ? 'es' : 'en', {
      month: 'short',
      year: 'numeric',
    }).format(new Date(`${firstDate}T12:00:00Z`))
  : '';

const items = [
  { icon: 'lucide:badge-check', label: copy.notarized },
  { icon: 'lucide:git-branch', label: copy.sourceAvailable },
  { icon: 'lucide:eye-off', label: copy.noTelemetry },
  { icon: 'lucide:file-check', label: copy.checksums },
  {
    icon: 'lucide:rocket',
    label: copy.velocity.replace('{count}', String(releaseCount)).replace('{since}', firstMonth),
  },
];
---

<section class="trust" aria-label={copy.aria}>
  <ul class="trust-list">
    {
      items.map((item) => (
        <li>
          <Icon name={item.icon} />
          <span>{item.label}</span>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .trust {
    border-block: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg-elevated) 55%, transparent);
  }
  .trust-list {
    max-width: var(--container-max);
    margin-inline: auto;
    padding: 0.875rem clamp(1rem, 4vw, 2rem);
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1.75rem;
    margin-block: 0;
  }
  .trust-list li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.01em;
    white-space: nowrap;
  }
  .trust-list svg {
    width: 15px;
    height: 15px;
    color: var(--color-accent);
    flex-shrink: 0;
  }
  @media (max-width: 640px) {
    .trust-list {
      gap: 0.625rem 1.25rem;
    }
    .trust-list li {
      font-size: 0.7rem;
    }
  }
</style>
