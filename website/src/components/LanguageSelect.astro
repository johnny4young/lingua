---
import {
  LOCALES,
  type Locale,
  getLocaleMeta,
  switchLocalePath,
  t,
} from '~/lib/i18n';

interface Props {
  locale: Locale;
  currentPath: string;
  compact?: boolean;
}

const { locale, currentPath, compact = false } = Astro.props;
const copy = t(locale);
const current = getLocaleMeta(locale);
---

<label class:list={['language-select', compact && 'is-compact']}>
  <span class="internal">{copy.common.languageSelect}</span>
  <select data-language-select aria-label={copy.common.languageSelect}>
    {
      LOCALES.map((item) => (
        <option value={switchLocalePath(currentPath, item.code)} data-locale={item.code} selected={item.code === current.code}>
          {item.shortLabel}
        </option>
      ))
    }
  </select>
</label>

<style>
  .language-select {
    position: relative;
    display: inline-flex;
    align-items: center;
  }
  .language-select select {
    appearance: none;
    width: 52px;
    height: 36px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background:
      linear-gradient(45deg, transparent 50%, var(--color-text-subtle) 50%) calc(100% - 12px) 15px / 4px 4px no-repeat,
      linear-gradient(135deg, var(--color-text-subtle) 50%, transparent 50%) calc(100% - 8px) 15px / 4px 4px no-repeat,
      color-mix(in srgb, var(--color-bg-elevated) 90%, var(--color-bg-sunken));
    color: var(--color-text-muted);
    font: 600 var(--text-xs) / 1 var(--font-mono);
    padding: 0 1.25rem 0 0.65rem;
    cursor: pointer;
    transition: border-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out),
      background-color var(--duration-fast) var(--ease-out);
  }
  .language-select select:hover,
  .language-select select:focus-visible {
    color: var(--color-text);
    border-color: var(--color-accent-muted);
    outline: none;
  }
  .language-select.is-compact select {
    width: 100%;
  }
</style>
