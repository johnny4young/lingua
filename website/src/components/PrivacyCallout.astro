---
import { Icon } from 'astro-icon/components';
import { type Locale, localizePath, t } from '~/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = t(locale).home.privacyCallout;
---

<section class="callout-wrap">
  <aside class="privacy-callout">
    <div class="privacy-icon">
      <Icon name="lucide:shield-check" />
    </div>
    <div>
      <h3>{copy.title}</h3>
      <p>
        {copy.bodyStart}
        <a href={localizePath(locale, '/privacy')}>{copy.link}</a>
        {copy.bodyEnd}
      </p>
    </div>
  </aside>
</section>

<style>
  .callout-wrap {
    padding-block: var(--space-section);
  }
  .privacy-callout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    padding: 1.75rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-accent-muted);
    background: color-mix(in srgb, var(--color-accent-muted) 18%, var(--color-bg-elevated));
  }
  .privacy-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--color-accent) 30%, transparent);
    color: var(--color-accent);
  }
  .privacy-icon svg {
    width: 22px;
    height: 22px;
  }
  .privacy-callout h3 {
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
  }
  .privacy-callout p {
    margin: 0;
    color: var(--color-text-muted);
  }
  .privacy-callout a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  @media (min-width: 768px) {
    .privacy-callout {
      grid-template-columns: auto 1fr;
      gap: 1.5rem;
    }
  }
</style>
