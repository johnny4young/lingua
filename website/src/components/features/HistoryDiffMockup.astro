---
/**
 * Mock of Lingua's execution-history panel with diff. Shows two consecutive
 * runs of the same snippet and a side-by-side diff of what changed.
 * All real divs / styled spans — no fake screenshot.
 */
import { Icon } from 'astro-icon/components';
import type { Locale } from '~/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isEs = locale === 'es';
---

<div class="history-shell">
  <header>
    <Icon name="lucide:history" />
    <span>{isEs ? 'Historial de ejecución' : 'Execution history'}</span>
    <span class="header-meta">{isEs ? 'últimos 2 runs · diff' : 'last 2 runs · diff view'}</span>
  </header>

  <div class="runs">
    <article class="run">
      <div class="run-meta">
        <span class="run-num">#42</span>
        <span class="run-time">{isEs ? 'hace 12s' : '12s ago'}</span>
        <span class="run-status ok">ok · 1.4 ms</span>
      </div>
      <pre class="run-code"><code><span class="ln-removed"><span class="ln-marker">-</span> const tier = <span class="str">'free'</span>;</span>
<span class="ln-removed"><span class="ln-marker">-</span> console.log(limits[tier]);</span>
<span class="ln-context"><span class="ln-marker"> </span> //=&gt; 5</span></code></pre>
    </article>

    <article class="run is-current">
      <div class="run-meta">
        <span class="run-num">#43</span>
        <span class="run-time">{isEs ? 'ahora' : 'just now'}</span>
        <span class="run-status ok">ok · 1.2 ms</span>
      </div>
      <pre class="run-code"><code><span class="ln-added"><span class="ln-marker">+</span> const tier = <span class="str">'pro'</span>;</span>
<span class="ln-added"><span class="ln-marker">+</span> console.log(limits[tier]);</span>
<span class="ln-context"><span class="ln-marker"> </span> //=&gt; 'unlimited'</span></code></pre>
    </article>
  </div>

  <footer class="hist-foot">
    <Icon name="lucide:undo-2" />
    <span>{isEs ? 'Haz click en un run anterior para restaurarlo. El historial queda local: nunca se transmite.' : 'Click any past run to restore it. History stays local — never transmitted.'}</span>
  </footer>
</div>

<style>
  .history-shell {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg-sunken);
    overflow: hidden;
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--color-text) 5%, transparent);
  }
  header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg-elevated) 92%, var(--color-bg-sunken));
    font-size: var(--text-small);
    font-weight: 600;
  }
  header svg { width: 14px; height: 14px; color: var(--color-accent); }
  .header-meta {
    margin-left: auto;
    color: var(--color-text-subtle);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
  }
  .runs {
    display: grid;
    grid-template-columns: 1fr;
  }
  .run {
    padding: 0.875rem 1rem 1rem;
    border-top: 1px solid var(--color-border);
  }
  .run:first-child { border-top: 0; }
  .run.is-current {
    background: color-mix(in srgb, var(--color-accent-muted) 12%, transparent);
  }
  .run-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-text-subtle);
  }
  .run-num {
    color: var(--color-text);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 1px 6px;
  }
  .run.is-current .run-num {
    color: var(--color-accent);
    border-color: var(--color-accent-muted);
  }
  .run-status.ok { color: var(--color-success); }
  .run-code {
    margin: 0;
    padding: 0.625rem 0.75rem;
    background: color-mix(in srgb, var(--color-bg-elevated) 95%, var(--color-bg-sunken));
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: 0.78rem;
    line-height: 1.55;
    overflow-x: auto;
  }
  .run-code code {
    font-family: var(--font-mono);
    color: var(--color-text);
    display: block;
    white-space: pre;
  }
  .ln-marker {
    display: inline-block;
    width: 12px;
    color: var(--color-text-subtle);
    user-select: none;
  }
  .ln-added {
    background: color-mix(in srgb, var(--color-success) 14%, transparent);
    color: var(--color-text);
    display: block;
  }
  .ln-removed {
    background: color-mix(in srgb, var(--color-danger) 12%, transparent);
    color: var(--color-text-muted);
    display: block;
    text-decoration: line-through;
    text-decoration-color: color-mix(in srgb, var(--color-danger) 60%, transparent);
  }
  .ln-context { display: block; color: var(--color-text-subtle); }
  .str { color: #fbbf24; }

  .hist-foot {
    padding: 0.75rem 1rem;
    border-top: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg-elevated) 88%, var(--color-bg-sunken));
    color: var(--color-text-muted);
    font-size: var(--text-small);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .hist-foot svg { width: 14px; height: 14px; color: var(--color-accent); }
</style>
