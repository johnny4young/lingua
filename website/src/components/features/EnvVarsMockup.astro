---
/**
 * Composed mockup of Lingua's three-tier environment variables panel.
 * Real divs that demonstrate how the global / project / tab scope cascade
 * actually behaves. Replace with screenshot/MP4 once internal ships them.
 */
import { Icon } from 'astro-icon/components';
import type { Locale } from '~/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isEs = locale === 'es';

const TIERS = [
  {
    id: 'global',
    scope: isEs ? 'Global' : 'Global',
    icon: 'globe',
    desc: isEs ? 'Disponible para cada snippet en cada proyecto.' : 'Available to every snippet across every project.',
    rows: [
      { key: 'GITHUB_TOKEN', value: '<redacted>', source: 'global' },
      { key: 'NODE_ENV',     value: 'development',         source: 'global' },
    ],
  },
  {
    id: 'project',
    scope: isEs ? 'Proyecto' : 'Project',
    icon: 'folder-open',
    desc: isEs ? 'Cargado solo para snippets dentro del root de proyecto activo.' : 'Loaded only for snippets inside the active project root.',
    rows: [
      { key: 'API_BASE_URL', value: 'https://staging.api', source: 'project' },
      { key: 'NODE_ENV',     value: 'staging',             source: isEs ? 'proyecto (sobrescribe global)' : 'project (overrides global)' },
    ],
  },
  {
    id: 'tab',
    scope: isEs ? 'Pestaña' : 'Tab',
    icon: 'panel-right',
    desc: isEs ? 'Gana. Defínelo inline para el snippet que ejecutas ahora.' : 'Wins. Set inline for the snippet you are running right now.',
    rows: [
      { key: 'API_BASE_URL', value: 'http://localhost:3000', source: isEs ? 'pestaña (sobrescribe proyecto)' : 'tab (overrides project)' },
    ],
  },
] as const;
---

<div class="env-shell">
  <header>
    <Icon name="lucide:settings-2" />
    <span>{isEs ? 'Variables de entorno' : 'Environment variables'}</span>
    <span class="header-meta">{isEs ? '3 capas · última escritura gana' : '3 tiers · last write wins'}</span>
  </header>

  <div class="tiers">
    {
      TIERS.map((tier, i) => (
        <article class="tier" data-tier={tier.id}>
          <div class="tier-head">
            <span class="tier-num">{i + 1}</span>
            <Icon name={`lucide:${tier.icon}`} />
            <h4>{tier.scope}</h4>
          </div>
          <p class="tier-desc">{tier.desc}</p>
          <ul class="rows">
            {
              tier.rows.map((row) => (
                <li>
                  <span class="row-key">{row.key}</span>
                  <span class="row-eq">=</span>
                  <span class="row-value">{row.value}</span>
                  <span class="row-source">{row.source}</span>
                </li>
              ))
            }
          </ul>
        </article>
      ))
    }
  </div>

  <footer class="env-foot">
    <Icon name="lucide:arrow-down" />
    {isEs ? 'Efectivo en runtime:' : 'Effective at runtime:'} <code>API_BASE_URL=http://localhost:3000</code>, <code>NODE_ENV=staging</code>, <code>GITHUB_TOKEN=&lt;redacted&gt;</code>
  </footer>
</div>

<style>
  .env-shell {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg-sunken);
    overflow: hidden;
    box-shadow: inset 0 1px 0 color-mix(in srgb, var(--color-text) 5%, transparent);
  }
  header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg-elevated) 92%, var(--color-bg-sunken));
    font-size: var(--text-small);
    font-weight: 600;
  }
  header svg { width: 14px; height: 14px; color: var(--color-accent); }
  .header-meta {
    margin-left: auto;
    color: var(--color-text-subtle);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
  }
  .tiers {
    display: grid;
    grid-template-columns: 1fr;
  }
  .tier {
    padding: 1rem 1rem 1.25rem;
    border-top: 1px solid var(--color-border);
  }
  .tier:first-child { border-top: 0; }
  .tier-head {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .tier-num {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .tier-head svg {
    width: 14px;
    height: 14px;
    color: var(--color-accent);
  }
  .tier-head h4 {
    margin: 0;
    font-size: var(--text-small);
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--color-text);
  }
  .tier[data-tier="tab"] .tier-num {
    background: var(--color-accent);
    color: var(--color-accent-ink, #04161b);
    border-color: var(--color-accent);
  }
  .tier-desc {
    margin: 0.4rem 0 0.75rem;
    color: var(--color-text-muted);
    font-size: var(--text-small);
    line-height: 1.5;
  }
  .rows {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .rows li {
    display: grid;
    grid-template-columns: minmax(110px, 0.9fr) 14px minmax(120px, 1.1fr) auto;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.4rem 0.625rem;
    background: color-mix(in srgb, var(--color-bg-elevated) 90%, var(--color-bg-sunken));
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    overflow: hidden;
  }
  .row-key { color: var(--color-text); font-weight: 600; }
  .row-eq { color: var(--color-text-subtle); }
  .row-value { color: var(--color-accent); overflow: hidden; text-overflow: ellipsis; }
  .row-source {
    color: var(--color-text-subtle);
    font-size: 0.7rem;
    white-space: nowrap;
  }

  .env-foot {
    padding: 0.75rem 1rem;
    border-top: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-accent-muted) 18%, var(--color-bg-elevated));
    color: var(--color-text);
    font-size: var(--text-small);
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .env-foot svg { width: 14px; height: 14px; color: var(--color-accent); }
  .env-foot code {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    background: var(--color-bg-sunken);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 1px 6px;
    color: var(--color-accent);
  }

  @media (max-width: 600px) {
    .rows li {
      grid-template-columns: 1fr;
      gap: 2px;
      padding: 0.5rem 0.625rem;
    }
    .row-eq { display: none; }
    .row-source { font-size: 0.7rem; }
  }
</style>
