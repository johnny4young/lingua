---
/**
 * Visual representation of the install verification flow. Keep the claims
 * aligned with the release workflow: every artifact has a checksum, while
 * platform signatures depend on the configured release credentials.
 */
import { Icon } from 'astro-icon/components';
import type { Locale } from '~/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isEs = locale === 'es';
---

<div class="security-grid">
  <div class="verification-card">
    <header>
      <Icon name="lucide:terminal" />
      <span>{isEs ? 'Verificar descarga' : 'Verify your download'}</span>
    </header>
    <pre class="verification-code"><code><span class="cmd-prefix">$</span> shasum -a 256 -c SHA256SUMS.txt
<span class="ok">Lingua-&lt;version&gt;-mac-arm64.dmg:</span>        <span class="ok-mark">OK</span>
<span class="ok">Lingua-&lt;version&gt;-mac-x64.dmg:</span>          <span class="ok-mark">OK</span>
<span class="ok">Lingua-&lt;version&gt;-win-x64.exe:</span>          <span class="ok-mark">OK</span>
<span class="ok">Lingua-&lt;version&gt;-linux-x86_64.AppImage:</span> <span class="ok-mark">OK</span></code></pre>
  </div>

  <div class="verification-card">
    <header>
      <Icon name="lucide:badge-check" />
      <span>{isEs ? 'Controles de distribución' : 'Distribution checks'}</span>
    </header>
    <ul class="sig-list">
      <li>
        <span class="sig-platform">macOS</span>
        <span class="sig-detail">{isEs ? 'Firma Developer ID y notarización verificadas en releases públicas' : 'Developer ID signing and notarization verified for public releases'}</span>
      </li>
      <li>
        <span class="sig-platform">Windows</span>
        <span class="sig-detail">{isEs ? 'SHA-256 · Authenticode cuando hay certificado configurado' : 'SHA-256 · Authenticode when a certificate is configured'}</span>
      </li>
      <li>
        <span class="sig-platform">Linux</span>
        <span class="sig-detail">{isEs ? 'AppImage · integridad verificada con SHA-256' : 'AppImage · integrity verified with SHA-256'}</span>
      </li>
    </ul>
  </div>
</div>

<style>
  .security-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  .verification-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg-sunken);
    overflow: hidden;
    min-width: 0;
  }
  .verification-card header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg-elevated) 92%, var(--color-bg-sunken));
    font-size: var(--text-small);
    font-weight: 600;
  }
  .verification-card header svg { width: 14px; height: 14px; color: var(--color-accent); }
  .verification-code {
    margin: 0;
    padding: 0.875rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.55;
    color: var(--color-text);
    overflow-x: auto;
  }
  .verification-code code { font-family: inherit; white-space: pre; }
  .cmd-prefix { color: var(--color-accent); user-select: none; margin-right: 6px; }
  .ok { color: var(--color-text); }
  .ok-mark { color: var(--color-success); font-weight: 700; }

  .sig-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .sig-list li {
    display: grid;
    grid-template-columns: 86px 1fr;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border);
    font-size: var(--text-small);
  }
  .sig-list li:last-child { border-bottom: 0; }
  .sig-platform {
    font-family: var(--font-mono);
    color: var(--color-accent);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0;
  }
  .sig-detail { color: var(--color-text-muted); }

  @media (min-width: 720px) {
    .security-grid { grid-template-columns: 1.1fr 1fr; }
  }
</style>
