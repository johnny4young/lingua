---
/**
 * Visual representation of the install verification flow:
 * SHA256SUMS check + signed binary stamp. Real divs, real text — no fake
 * terminal animation, no aspirational copy.
 */
import { Icon } from 'astro-icon/components';
import type { Locale } from '~/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isEs = locale === 'es';
---

<div class="sec-shell">
  <div class="sec-card">
    <header>
      <Icon name="lucide:terminal" />
      <span>{isEs ? 'Verificar descarga' : 'Verify your download'}</span>
    </header>
    <pre class="sec-code"><code><span class="cmd-prefix">$</span> shasum -a 256 -c SHA256SUMS.txt
<span class="ok">Lingua-0.2.1-arm64.zip:</span> <span class="ok-mark">OK</span>
<span class="ok">Lingua-0.2.1-x64.zip:</span>   <span class="ok-mark">OK</span>
<span class="ok">LinguaSetup.exe:</span>        <span class="ok-mark">OK</span>
<span class="ok">lingua_0.2.1_amd64.deb:</span> <span class="ok-mark">OK</span></code></pre>
  </div>

  <div class="sec-card">
    <header>
      <Icon name="lucide:badge-check" />
      <span>{isEs ? 'Firmado y notarizado' : 'Signed & notarized'}</span>
    </header>
    <ul class="sig-list">
      <li>
        <span class="sig-platform">macOS</span>
        <span class="sig-detail">{isEs ? 'Apple Developer ID · notarizado · limpio para Gatekeeper' : 'Apple Developer ID · notarized · Gatekeeper-clean'}</span>
      </li>
      <li>
        <span class="sig-platform">Windows</span>
        <span class="sig-detail">{isEs ? 'Authenticode · reputación SmartScreen en progreso' : 'Authenticode · SmartScreen reputation accruing'}</span>
      </li>
      <li>
        <span class="sig-platform">Linux</span>
        <span class="sig-detail">{isEs ? '.deb y .rpm con firma de maintainer' : '.deb & .rpm with maintainer signature'}</span>
      </li>
    </ul>
  </div>
</div>

<style>
  .sec-shell {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  .sec-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg-sunken);
    overflow: hidden;
    min-width: 0;
  }
  .sec-card header {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg-elevated) 92%, var(--color-bg-sunken));
    font-size: var(--text-small);
    font-weight: 600;
  }
  .sec-card header svg { width: 14px; height: 14px; color: var(--color-accent); }
  .sec-code {
    margin: 0;
    padding: 0.875rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.55;
    color: var(--color-text);
    overflow-x: auto;
  }
  .sec-code code { font-family: inherit; white-space: pre; }
  .cmd-prefix { color: var(--color-accent); user-select: none; margin-right: 6px; }
  .ok { color: var(--color-text); }
  .ok-mark { color: var(--color-success); font-weight: 700; }

  .sig-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .sig-list li {
    display: grid;
    grid-template-columns: 86px 1fr;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border);
    font-size: var(--text-small);
  }
  .sig-list li:last-child { border-bottom: 0; }
  .sig-platform {
    font-family: var(--font-mono);
    color: var(--color-accent);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0;
  }
  .sig-detail { color: var(--color-text-muted); }

  @media (min-width: 720px) {
    .sec-shell { grid-template-columns: 1.1fr 1fr; }
  }
</style>
