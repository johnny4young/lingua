---
import { Icon } from 'astro-icon/components';
import { type Locale, t } from '~/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = t(locale);
const CARDS = copy.home.why.cards;
---

<section class="why">
  <header class="why-head">
    <p class="eyebrow">{copy.home.why.eyebrow}</p>
    <h2>{copy.home.why.title}</h2>
  </header>

  <div class="why-grid">
    {
      CARDS.map((c, index) => (
        <article class="card why-card">
          <div class="why-meta" aria-hidden="true">
            <span class="why-number">0{index + 1}</span>
            <Icon name={`lucide:${c.icon}`} class="why-icon" />
          </div>
          <h3>{c.title}</h3>
          <p>{c.body}</p>
        </article>
      ))
    }
  </div>
</section>

<style>
  .why {
    position: relative;
    padding-block: var(--space-section-lg);
  }
  .why-head {
    max-width: 760px;
    margin-bottom: 2.5rem;
  }
  .why-head h2 {
    font-size: var(--text-h2);
    letter-spacing: var(--tracking-tight);
    font-weight: 700;
    margin: 0.75rem 0 0;
    line-height: 1.2;
  }
  .why-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  /* Asymmetric bento: the first and last cards stretch, forming a
     diagonal — deliberately not four identical towers. */
  .why-card:first-child,
  .why-card:last-child {
    background:
      radial-gradient(28rem 18rem at 4% 0%, color-mix(in srgb, var(--color-accent) 13%, transparent), transparent 72%),
      linear-gradient(145deg, color-mix(in srgb, var(--color-text) 4%, transparent), transparent 46%),
      color-mix(in srgb, var(--color-bg-elevated) 90%, transparent);
  }
  .why-card {
    min-height: 250px;
    display: flex;
    flex-direction: column;
    justify-content: end;
    padding: clamp(1.5rem, 3vw, 2.4rem);
  }
  .why-card::after {
    content: "";
    position: absolute;
    inset: auto -15% -45% auto;
    width: 12rem;
    aspect-ratio: 1;
    border: 1px solid color-mix(in srgb, var(--color-signal) 20%, transparent);
    border-radius: 50%;
    transition: transform 600ms var(--ease-out), border-color 600ms var(--ease-out);
  }
  .why-card:hover::after {
    transform: scale(1.3) translate(-10%, -10%);
    border-color: color-mix(in srgb, var(--color-signal) 55%, transparent);
  }
  .why-card h3 {
    position: relative;
    z-index: 2;
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2vw, 1.75rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    font-weight: 720;
    margin: 0 0 0.5rem;
  }
  .why-card p {
    position: relative;
    z-index: 2;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
  }
  .why-meta {
    position: absolute;
    inset: 1.25rem 1.25rem auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .why-number {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    color: var(--color-text-subtle);
  }
  .why-icon {
    width: 32px;
    height: 32px;
    padding: 7px;
    border-radius: 10px;
    color: var(--color-accent-ink);
    background: linear-gradient(135deg, var(--color-accent), color-mix(in srgb, var(--color-signal) 78%, var(--color-accent)));
    box-shadow: 0 12px 34px -14px var(--color-accent);
  }
  @media (min-width: 768px) {
    .why-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (min-width: 1100px) {
    .why-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
    .why-card:first-child,
    .why-card:last-child {
      grid-column: span 2;
      min-height: 300px;
    }
    .why-card:first-child p,
    .why-card:last-child p {
      max-width: 52ch;
    }
  }
</style>
