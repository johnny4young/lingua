---
import { Icon } from 'astro-icon/components';
import LanguageSelect from './LanguageSelect.astro';
import { NAV, SITE } from '~/lib/site';
import { type Locale, localizePath, stripLocaleFromPath, t } from '~/lib/i18n';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const copy = t(locale);
const path = stripLocaleFromPath(currentPath);
function isActive(href: string): boolean {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(`${href}/`);
}
---

<a href="#main" class="skip-link">{copy.common.skipToContent}</a>

<header class="site-header">
  <div class="container header-inner">
    <a href={localizePath(locale, '/')} class="brand" aria-label={copy.common.homeAria}>
      <Icon name="lucide:terminal" class="brand-mark" />
      <span class="brand-name">Lingua</span>
    </a>

    <nav class="primary-nav" aria-label={copy.common.primaryNav}>
      {
        NAV.map((item) => (
          <a href={localizePath(locale, item.href)} class:list={['nav-link', isActive(item.href) && 'is-active']}>
            {copy.nav[item.key]}
          </a>
        ))
      }
    </nav>

    <div class="header-actions">
      <a href={SITE.social.githubUrl} class="icon-link" aria-label={copy.common.sourceOnGitHub} rel="external noopener">
        <Icon name="lucide:github" />
      </a>
      <LanguageSelect locale={locale} currentPath={currentPath} />
      <button id="theme-toggle" class="icon-link" aria-label={copy.common.themeToggle}>
        <Icon name="lucide:sun-moon" />
      </button>
      <a href={localizePath(locale, '/releases')} class="btn btn-primary header-cta">
        {copy.common.download}
      </a>
      <button id="nav-toggle" class="icon-link nav-toggle" aria-label={copy.common.openMenu} aria-expanded="false">
        <Icon name="lucide:menu" />
      </button>
    </div>
  </div>

  <nav id="mobile-nav" class="mobile-nav" hidden aria-label={copy.common.mobilePrimaryNav}>
    {NAV.map((item) => <a href={localizePath(locale, item.href)} class="mobile-nav-link">{copy.nav[item.key]}</a>)}
    <div class="mobile-language">
      <LanguageSelect locale={locale} currentPath={currentPath} compact />
    </div>
    <a href={SITE.social.githubUrl} class="mobile-nav-link">{copy.common.github}</a>
    <a href={localizePath(locale, '/releases')} class="btn btn-primary mobile-cta">{copy.common.downloadForDesktop}</a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0.75rem;
    z-index: 50;
    padding-top: 0.75rem;
    pointer-events: none;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    min-height: 58px;
    padding-block: 0.5rem;
    border: 1px solid color-mix(in srgb, var(--color-border-strong) 78%, transparent);
    border-radius: 1.15rem;
    background: color-mix(in srgb, var(--color-bg-sunken) 76%, transparent);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--color-text) 8%, transparent),
      0 24px 70px -36px rgb(0 0 0 / 0.92);
    backdrop-filter: blur(24px) saturate(140%);
    pointer-events: auto;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    font-family: var(--font-display);
    font-weight: 780;
    letter-spacing: -0.045em;
  }
  .brand-mark {
    width: 30px;
    height: 30px;
    padding: 6px;
    border-radius: 9px;
    color: var(--color-accent-ink);
    background: linear-gradient(135deg, var(--color-accent), var(--color-signal));
    box-shadow: 0 0 28px -8px var(--color-accent);
  }
  .brand-name {
    font-size: 1.18rem;
  }
  .primary-nav {
    display: none;
    gap: 1.5rem;
    margin-left: 2rem;
    flex: 1;
  }
  .nav-link {
    color: var(--color-text-muted);
    font-size: var(--text-small);
    font-weight: 650;
    position: relative;
    padding: 0.45rem 0.7rem;
    border-radius: 999px;
    transition: color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out);
  }
  .nav-link:hover, .nav-link.is-active {
    color: var(--color-text);
    background: color-mix(in srgb, var(--color-accent-muted) 42%, transparent);
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 999px;
    color: var(--color-text-muted);
    transition: color var(--duration-fast) var(--ease-out), background var(--duration-fast) var(--ease-out);
  }
  .icon-link:hover {
    color: var(--color-text);
    background: color-mix(in srgb, var(--color-bg-elevated) 86%, var(--color-accent-muted));
  }
  .icon-link svg {
    width: 18px;
    height: 18px;
  }
  .header-cta {
    padding: 0.58rem 1rem;
  }
  .nav-toggle {
    display: inline-flex;
  }
  .mobile-nav {
    display: flex;
    flex-direction: column;
    padding: 1rem;
    gap: 0.5rem;
    margin: 0.5rem clamp(1rem, 4vw, 2rem) 0;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--color-bg-sunken) 90%, transparent);
    box-shadow: var(--shadow-lift);
    backdrop-filter: blur(24px);
    pointer-events: auto;
  }
  .mobile-nav-link {
    padding: 0.75rem;
    border-radius: var(--radius);
    color: var(--color-text);
  }
  .mobile-nav-link:hover {
    background: var(--color-bg);
  }
  .mobile-cta {
    margin-top: 0.5rem;
    justify-content: center;
  }
  .mobile-language {
    padding: 0.25rem 0.75rem;
  }
  @media (min-width: 1024px) {
    .primary-nav {
      display: flex;
    }
    .nav-toggle {
      display: none;
    }
    .mobile-nav {
      display: none !important;
    }
  }
  @media (max-width: 1023px) {
    .site-header {
      top: 0.35rem;
      padding-top: 0.35rem;
    }
    .header-inner {
      margin-inline: 0.75rem;
      width: auto;
      padding-inline: 0.7rem;
    }
    .header-actions .icon-link:first-child,
    .header-actions > :global(.language-select) {
      display: none;
    }
    .header-cta {
      display: none;
    }
  }
</style>
