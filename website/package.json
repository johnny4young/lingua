{
  "name": "lingua-website",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "description": "Marketing site for Lingua (linguacode.dev). Astro 6 + Tailwind v4, deployed to Cloudflare Pages. Lives inside the lingua monorepo as a standalone (--ignore-workspace) package.",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/build-press-kit-zip.mjs",
    "build": "astro build",
    "postbuild": "node scripts/validate-jsonld.mjs && node scripts/apply-csp-hashes.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "sync:content": "node scripts/sync-from-main.mjs",
    "sync:check": "node scripts/sync-from-main.mjs --check",
    "sync:commit": "node scripts/sync-and-push.mjs",
    "sync:push": "node scripts/sync-and-push.mjs --push"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/manrope": "^5.2.8",
    "@iconify-json/lucide": "^1.2.116",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.6",
    "astro-icon": "^1.1.5",
    "shiki": "^4.3.1",
    "tailwindcss": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "yaml": "^2.8.4"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
