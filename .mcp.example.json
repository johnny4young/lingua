{
  "mcpServers": {
    "electron-stagewright": {
      "command": "npx",
      "args": [
        "--prefix",
        "/tmp",
        "-y",
        "--package",
        "@electron-stagewright/core",
        "--package",
        "playwright",
        "electron-stagewright",
        "--allow-eval",
        "--screenshot-dir",
        "/abs/path/to/lingua/output/stagewright/screenshots"
      ]
    }
  }
}
