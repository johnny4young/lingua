# Public build-time defaults for local development.
#
# Copy to `.env` only when you need to override the defaults. Do not put
# private keys, license tokens, API tokens, signing certificates, or webhook
# secrets in committed env files.

# Optional. Missing value keeps local web builds on local/offline license
# verification only.
VITE_LINGUA_LICENSE_SERVER_URL=

# Optional desktop runtime override for the same license-server base URL.
# Packaged builds can also bake this from `.env.production`.
LINGUA_LICENSE_SERVER_URL=

# Optional Ed25519 public key JWK used by renderer builds to verify license
# tokens. This is public material. The private key belongs only in the
# license-server secret store.
#
# Leave these EMPTY for normal local dev. To exercise paid-tier UI, run
# `pnpm dev:web:pro` / `pnpm dev:desktop:pro` — they mint a throwaway
# keypair and inject the public key via process.env (which Vite prioritizes
# over .env files), then print a matching token to paste.
#
# FOOTGUN: do NOT paste a long-lived public key here. A stale value makes
# plain `dev:web` / `dev:desktop` (and manual `vite` launches) verify
# against a key whose private half is gone, so freshly-minted tokens fail
# with the misleading "signature does not match". If you hit that, clear
# these two lines.
LINGUA_LICENSE_PUBLIC_KEY_JWK=
VITE_LINGUA_LICENSE_PUBLIC_KEY_JWK=

# Optional update-server overrides. Defaults point at
# https://updates.linguacode.dev when unset.
LINGUA_UPDATE_URL=
VITE_LINGUA_UPDATE_SERVER_URL=

# Optional app metadata overrides. Vite seeds VITE_LINGUA_APP_VERSION from
# package.json#version automatically; override only for targeted release tests.
VITE_LINGUA_APP_VERSION=
LINGUA_WEBSITE_URL=

# Optional telemetry endpoint. Telemetry is opt-in in the app and disabled
# when this value is unset.
VITE_LINGUA_TELEMETRY_URL=

# Set to 1 to disable telemetry regardless of user consent.
VITE_LINGUA_TELEMETRY_DISABLED=1

# Optional crash reporter endpoint for packaged desktop builds. Crash
# reporting is opt-in and disabled when this value is unset.
LINGUA_CRASH_REPORTER_URL=

# Set to 1 to disable crash reporting regardless of user consent.
LINGUA_CRASH_REPORTER_DISABLED=1

# Optional standalone web build runtime prefix. Production deploys set this
# to the public R2 runtime base because Cloudflare Pages rejects individual
# Ruby/DuckDB WASM assets above 25 MiB. Local dev can leave it unset.
VITE_LINGUA_WEB_RUNTIME_BASE=
