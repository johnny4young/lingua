# Public build-time defaults for local development.
#
# Copy to `.env` only when you need to override the defaults. Do not put
# private keys, license tokens, API tokens, signing certificates, or webhook
# secrets in committed env files.

# Optional. Missing value keeps local web builds on local/offline license
# verification only.
VITE_LINGUA_LICENSE_SERVER_URL=

# Optional Ed25519 public key JWK used by renderer builds to verify license
# tokens. This is public material. The private key belongs only in the
# license-server secret store.
LINGUA_LICENSE_PUBLIC_KEY_JWK=
VITE_LINGUA_LICENSE_PUBLIC_KEY_JWK=

# Optional telemetry endpoint. Telemetry is opt-in in the app and disabled
# when this value is unset.
VITE_LINGUA_TELEMETRY_URL=

# Set to 1 to disable telemetry regardless of user consent.
VITE_LINGUA_TELEMETRY_DISABLED=1

# Optional crash reporter endpoint for packaged desktop builds. Crash
# reporting is opt-in and disabled when this value is unset.
LINGUA_CRASH_REPORTER_URL=

# Set to 1 to disable crash reporting regardless of user consent.
LINGUA_CRASH_REPORTER_DISABLED=1
